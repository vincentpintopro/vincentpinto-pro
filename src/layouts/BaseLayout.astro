---
import Nav from '../components/Nav.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	/** Utilise `title` tel quel dans <title>, sans ajouter "· SITE_TITLE" (utile quand title contient déjà le nom du site, ex: l'accueil). */
	rawTitle?: boolean;
}

const { title, description = SITE_DESCRIPTION, rawTitle = false } = Astro.props;

const pageTitle = !title ? SITE_TITLE : rawTitle ? title : `${title} · ${SITE_TITLE}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og-image.jpg', Astro.site);

// Astro déduit la langue courante ("fr" ou "en") depuis la config i18n
// et l'URL en cours (ex: /en/... -> "en", sinon -> "fr" par défaut).
const lang = Astro.currentLocale ?? 'fr';
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="canonical" href={canonicalURL} />

		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />

		<!-- Open Graph : contrôle l'aperçu quand le lien est partagé (réseaux sociaux, Slack...) -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:site_name" content={SITE_TITLE} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content={ogImageURL} />
	</head>
	<body>
		<header>
			<Nav />
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<p>
				&copy; {new Date().getFullYear()} {SITE_TITLE} |{' '}
				<a href="/mentions-legales">Mentions légales</a>
			</p>
		</footer>
	</body>
</html>
